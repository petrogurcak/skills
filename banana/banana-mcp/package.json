{
  "name": "banana-mcp",
  "version": "1.0.0",
  "description": "MCP server for Image Generation using Gemini 2.0 Pro/Flash with Imagen 3",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "banana-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "npm run build && node dist/index.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "gemini",
    "image-generation",
    "imagen",
    "banana"
  ],
  "author": "Petr",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@google/generative-ai": "^0.21.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  }
}
